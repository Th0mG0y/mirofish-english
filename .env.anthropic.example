# ============================================
# MiroFish Configuration (Anthropic + OpenAI vectors)
# Copy this file to .env and fill in your real values
# ============================================

# ============= Main App LLM =============
MIROFISH_LLM_PROVIDER=anthropic # main app uses Claude in this preset
LLM_API_KEY=your-openai-api-key-here # still required because embeddings and reranking use OpenAI
LLM_BASE_URL=https://api.openai.com/v1 # default OpenAI base URL for vector slots
LLM_MODEL_NAME=gpt-5.4-mini # OpenAI model used for the OpenAI-based slots
OPENAI_CLI_USE_CREDENTIALS=false
OPENAI_CLI_CREDENTIALS_FILE=~/.codex/auth.json
ANTHROPIC_API_KEY=your-anthropic-api-key-here # your real Anthropic API key
ANTHROPIC_MODEL_NAME=claude-sonnet-4-6 # Claude model for the app and Graphiti extraction
# Optional: best-effort reuse of credentials cached by Claude Code.
# This only works when the cached file contains a reusable API key.
CLAUDE_CLI_USE_CREDENTIALS=false
CLAUDE_CLI_CREDENTIALS_FILE=~/.claude/.credentials.json

# ============= Search =============
MIROFISH_SEARCH_PROVIDER=anthropic # Anthropic built-in web search
MIROFISH_SEARCH_MODEL=claude-sonnet-4-6 # search model
MIROFISH_MAX_SEARCHES_PER_AGENT=5 # raise for more search calls, lower to control cost
MIROFISH_ENABLE_SEARCH_ENRICHMENT=false # true enables automatic search enrichment during some flows
MIROFISH_NEWS_INJECTION_INTERVAL=0 # 0 disables scheduled news injection

# ============= Graphiti Extraction LLM =============
GRAPHITI_LLM_PROVIDER=anthropic # Graphiti extraction also uses Claude here
# Leave blank to reuse `ANTHROPIC_API_KEY`.
GRAPHITI_LLM_API_KEY=
# Anthropic does not need a custom base URL in normal setups.
GRAPHITI_LLM_BASE_URL=
GRAPHITI_LLM_MODEL=claude-sonnet-4-6 # Graphiti extraction model
# Reasoning effort for GPT-5.x models: none, low, medium, high, xhigh (ignored for non-GPT-5 models)
GRAPHITI_LLM_REASONING_EFFORT=low

# ============= Graphiti Embeddings (OpenAI) =============
GRAPHITI_EMBEDDER_PROVIDER=openai # use OpenAI for embeddings in this preset
# Leave blank to reuse `LLM_API_KEY`.
GRAPHITI_EMBEDDER_API_KEY=
# Leave blank to reuse `LLM_BASE_URL`.
GRAPHITI_EMBEDDER_BASE_URL=
GRAPHITI_EMBEDDER_MODEL=text-embedding-3-small # recommended OpenAI embedding model

# ============= Graphiti Reranking (OpenAI) =============
GRAPHITI_RERANKER_PROVIDER=openai # use OpenAI for reranking in this preset
# Leave blank to reuse `LLM_API_KEY`.
GRAPHITI_RERANKER_API_KEY=
# Leave blank to reuse `LLM_BASE_URL`.
GRAPHITI_RERANKER_BASE_URL=
GRAPHITI_RERANKER_MODEL=gpt-5.4-mini # reranker model

# ============= Local Neo4j =============
NEO4J_URI=bolt://localhost:7687 # local Neo4j Bolt URL
NEO4J_USER=neo4j # default Neo4j username
NEO4J_PASSWORD=password # replace with your real Neo4j password

# ============= Legacy Zep Compatibility =============
# Usually leave blank in this Graphiti version.
ZEP_API_KEY=

# ============= Localization =============
MIROFISH_TIMEZONE=us_eastern # examples: us_eastern, us_pacific, eu_central, eu_london, asia_beijing
MIROFISH_LOCALE=en-US # content locale
MIROFISH_REGION=US # regional hint

# ============= Flask =============
SECRET_KEY=mirofish-secret-key # replace in production
FLASK_DEBUG=True # True for local development, False for production

# ============= OASIS Simulation =============
OASIS_DEFAULT_MAX_ROUNDS=10 # default simulation length

# ============= Report Agent =============
REPORT_AGENT_MAX_TOOL_CALLS=5 # more tool calls means deeper but costlier reports
REPORT_AGENT_MAX_REFLECTION_ROUNDS=2 # more reflection means deeper but slower reports
REPORT_AGENT_TEMPERATURE=0.5 # lower is steadier, higher is more creative
