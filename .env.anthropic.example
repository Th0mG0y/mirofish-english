# ============================================
# MiroFish Configuration (Anthropic-first)
# Copy this file to .env and fill in your real API keys
# ============================================

# ============= Core LLM Configuration =============
MIROFISH_LLM_PROVIDER=anthropic

# OpenAI-compatible configuration
# Still required by this Graphiti build for embeddings and reranking
LLM_API_KEY=your-openai-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o-mini

# Anthropic configuration
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL_NAME=claude-sonnet-4-6

# ============= Search Configuration =============
MIROFISH_SEARCH_PROVIDER=anthropic
MIROFISH_SEARCH_MODEL=claude-sonnet-4-6
MIROFISH_MAX_SEARCHES_PER_AGENT=5
MIROFISH_ENABLE_SEARCH_ENRICHMENT=false
MIROFISH_NEWS_INJECTION_INTERVAL=0

# ============= Legacy Zep Configuration =============
# Not used by the Graphiti graph-building path
ZEP_API_KEY=

# ============= Neo4j Configuration =============
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ============= Localization =============
MIROFISH_TIMEZONE=us_eastern
MIROFISH_LOCALE=en-US
MIROFISH_REGION=US

# ============= Flask Configuration =============
SECRET_KEY=mirofish-secret-key
FLASK_DEBUG=True

# ============= OASIS Simulation =============
OASIS_DEFAULT_MAX_ROUNDS=10

# ============= Report Agent =============
REPORT_AGENT_MAX_TOOL_CALLS=5
REPORT_AGENT_MAX_REFLECTION_ROUNDS=2
REPORT_AGENT_TEMPERATURE=0.5
# ============================================
# MiroFish Configuration (Anthropic-first)
# Copy this file to .env and fill in your real API keys
# ============================================

# ============= Core LLM Configuration =============
# Main app provider
MIROFISH_LLM_PROVIDER=anthropic

# OpenAI-compatible configuration
# Still required by this Graphiti build for embeddings and reranking
LLM_API_KEY=your-openai-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o-mini

# Anthropic configuration
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL_NAME=claude-sonnet-4-6

# ============= Search Configuration =============
# Search can use the same provider as the main app
MIROFISH_SEARCH_PROVIDER=anthropic
MIROFISH_SEARCH_MODEL=claude-sonnet-4-6
MIROFISH_MAX_SEARCHES_PER_AGENT=5
MIROFISH_ENABLE_SEARCH_ENRICHMENT=false
MIROFISH_NEWS_INJECTION_INTERVAL=0

# ============= Legacy Zep Configuration =============
# Not used by the Graphiti graph-building path
ZEP_API_KEY=

# ============= Neo4j Configuration =============
# Used by Graphiti for local knowledge graph storage
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ============= Localization =============
MIROFISH_TIMEZONE=us_eastern
MIROFISH_LOCALE=en-US
MIROFISH_REGION=US

# ============= Flask Configuration =============
SECRET_KEY=mirofish-secret-key
FLASK_DEBUG=True

# ============= OASIS Simulation =============
OASIS_DEFAULT_MAX_ROUNDS=10

# ============= Report Agent =============
REPORT_AGENT_MAX_TOOL_CALLS=5
REPORT_AGENT_MAX_REFLECTION_ROUNDS=2
REPORT_AGENT_TEMPERATURE=0.5
