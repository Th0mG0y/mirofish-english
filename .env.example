# ============================================
# MiroFish Configuration
# Copy this file to .env and fill in your values
# ============================================

# ============= Core LLM Configuration =============
# Primary LLM provider: "openai" or "anthropic"
MIROFISH_LLM_PROVIDER=openai

# OpenAI Configuration (used when LLM_PROVIDER=openai, supports any OpenAI-compatible API)
LLM_API_KEY=your-openai-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o-mini

# Anthropic Configuration (used when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL_NAME=claude-haiku-4-5

# ============= Search Configuration =============
# Search provider: "openai" or "anthropic" (can differ from main LLM provider)
MIROFISH_SEARCH_PROVIDER=openai
# Optional: specific model for search (empty = use provider default)
MIROFISH_SEARCH_MODEL=
# Maximum web searches per agent per session
MIROFISH_MAX_SEARCHES_PER_AGENT=5
# Enable automatic search enrichment during graph building (true/false)
MIROFISH_ENABLE_SEARCH_ENRICHMENT=false
# News injection interval in seconds (0 = disabled)
MIROFISH_NEWS_INJECTION_INTERVAL=0

# ============= Zep Configuration =============
ZEP_API_KEY=your-zep-api-key-here

# ============= Neo4j Configuration =============
# Used by Graphiti for local knowledge graph storage
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ============= Localization =============
# Timezone preset: us_eastern, us_pacific, eu_central, eu_london, asia_beijing
MIROFISH_TIMEZONE=us_eastern
# Locale for content generation
MIROFISH_LOCALE=en-US
# Region identifier
MIROFISH_REGION=US

# ============= Flask Configuration =============
SECRET_KEY=mirofish-secret-key
FLASK_DEBUG=True

# ============= OASIS Simulation =============
OASIS_DEFAULT_MAX_ROUNDS=10

# ============= Report Agent =============
REPORT_AGENT_MAX_TOOL_CALLS=5
REPORT_AGENT_MAX_REFLECTION_ROUNDS=2
REPORT_AGENT_TEMPERATURE=0.5

# ============= Boost LLM Configuration (optional) =============
# Note: If you do not use the boost configuration, do not include the entries below
# LLM_BOOST_API_KEY=your_api_key_here
# LLM_BOOST_BASE_URL=your_base_url_here
# LLM_BOOST_MODEL_NAME=your_model_name_here
