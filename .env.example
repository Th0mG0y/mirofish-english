# ============================================
# MiroFish Configuration
# Copy this file to .env and replace the placeholders
# ============================================

# ============= Main App LLM =============
# Use "openai" for OpenAI or any OpenAI-compatible server.
# Use "anthropic" for Claude.
MIROFISH_LLM_PROVIDER=openai # openai or anthropic
LLM_API_KEY=your-openai-api-key-here # real OpenAI key, or "ollama"/"lm-studio" for local OpenAI-compatible servers
LLM_BASE_URL=https://api.openai.com/v1 # OpenAI: https://api.openai.com/v1 | Ollama: http://localhost:11434/v1 | LM Studio: http://localhost:1234/v1
LLM_MODEL_NAME=gpt-5.4-mini # OpenAI example: gpt-5.4-mini | Ollama example: qwen3:14b | LM Studio: your loaded chat model name
# Optional: best-effort reuse of credentials cached by the OpenAI CLI / Codex CLI.
# This only works when the cached file contains a reusable API key.
OPENAI_CLI_USE_CREDENTIALS=false
OPENAI_CLI_CREDENTIALS_FILE=~/.codex/auth.json
# Fill only when any provider slot uses anthropic.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_NAME=claude-sonnet-4-6 # Claude model to use when a slot is set to anthropic
# Optional: best-effort reuse of credentials cached by Claude Code.
# This only works when the cached file contains a reusable API key.
CLAUDE_CLI_USE_CREDENTIALS=false
CLAUDE_CLI_CREDENTIALS_FILE=~/.claude/.credentials.json

# ============= Search =============
# Built-in web search works with real OpenAI or Anthropic APIs.
MIROFISH_SEARCH_PROVIDER=openai # openai or anthropic; avoid local Ollama/LM Studio here if you need built-in web search
# Blank uses the provider default; examples: gpt-5.4-mini or claude-sonnet-4-6.
MIROFISH_SEARCH_MODEL=
MIROFISH_MAX_SEARCHES_PER_AGENT=5 # raise for more search calls, lower to control cost
MIROFISH_ENABLE_SEARCH_ENRICHMENT=false # true to let the app pull web context automatically, false for cheaper/simpler runs
MIROFISH_NEWS_INJECTION_INTERVAL=0 # 0 disables scheduled news injection; otherwise use seconds between injections

# ============= Graphiti Extraction LLM =============
# This is the text-generation model Graphiti uses to extract graph structure.
GRAPHITI_LLM_PROVIDER=openai # openai or anthropic
# Leave blank to reuse `LLM_API_KEY` or `ANTHROPIC_API_KEY` automatically.
GRAPHITI_LLM_API_KEY=
# Leave blank to reuse the matching provider default.
GRAPHITI_LLM_BASE_URL=
# Examples: gpt-5.4-mini, claude-sonnet-4-6, qwen3:14b, or your LM Studio chat model.
GRAPHITI_LLM_MODEL=
# Reasoning effort for GPT-5.x models: none, low, medium, high, xhigh (ignored for non-GPT-5 models)
GRAPHITI_LLM_REASONING_EFFORT=low

# ============= Graphiti Embeddings =============
# Provider must be one of: openai, ollama, lmstudio
GRAPHITI_EMBEDDER_PROVIDER=openai # openai, ollama, or lmstudio
# Leave blank to reuse the provider default; local servers can use `ollama` or `lm-studio`.
GRAPHITI_EMBEDDER_API_KEY=
# Blank reuses the provider default; Ollama defaults to http://localhost:11434/v1, LM Studio to http://localhost:1234/v1.
GRAPHITI_EMBEDDER_BASE_URL=
GRAPHITI_EMBEDDER_MODEL=text-embedding-3-small # OpenAI example: text-embedding-3-small | Ollama example: nomic-embed-text | LM Studio: your loaded embedding model

# ============= Graphiti Reranking =============
# For Ollama and LM Studio, reranking uses embedding similarity through the local embedding endpoint.
GRAPHITI_RERANKER_PROVIDER=openai # openai, ollama, or lmstudio
# Leave blank to reuse the provider default; local servers can use `ollama` or `lm-studio`.
GRAPHITI_RERANKER_API_KEY=
# Blank reuses the provider default; set only when you want a different endpoint.
GRAPHITI_RERANKER_BASE_URL=
GRAPHITI_RERANKER_MODEL=gpt-5.4-mini # OpenAI example: gpt-5.4-mini | local reranking usually reuses the embedding model name

# ============= Local Vector Backends =============
# Uncomment and adjust one of these blocks when you want local embeddings/reranking.
#
# Ollama example:
# GRAPHITI_EMBEDDER_PROVIDER=ollama # use Ollama for embeddings
# GRAPHITI_EMBEDDER_BASE_URL=http://localhost:11434/v1 # default Ollama OpenAI-compatible endpoint
# GRAPHITI_EMBEDDER_MODEL=nomic-embed-text # common Ollama embedding model
# GRAPHITI_RERANKER_PROVIDER=ollama # local reranking through Ollama embeddings
# GRAPHITI_RERANKER_BASE_URL=http://localhost:11434/v1 # usually same as embedder URL
# GRAPHITI_RERANKER_MODEL=nomic-embed-text # usually same as embedder model
#
# LM Studio example:
# GRAPHITI_EMBEDDER_PROVIDER=lmstudio # use LM Studio for embeddings
# GRAPHITI_EMBEDDER_BASE_URL=http://localhost:1234/v1 # default LM Studio OpenAI-compatible endpoint
# GRAPHITI_EMBEDDER_MODEL=text-embedding-nomic-embed-text-v1.5 # replace with the loaded LM Studio embedding model name
# GRAPHITI_RERANKER_PROVIDER=lmstudio # local reranking through LM Studio embeddings
# GRAPHITI_RERANKER_BASE_URL=http://localhost:1234/v1 # usually same as embedder URL
# GRAPHITI_RERANKER_MODEL=text-embedding-nomic-embed-text-v1.5 # usually same as embedder model

# ============= Legacy Zep Compatibility =============
# Not required for the Graphiti graph-building path.
# Usually leave blank unless you still use an untouched legacy Zep route.
ZEP_API_KEY=

# ============= Neo4j =============
NEO4J_URI=bolt://localhost:7687 # local Neo4j Bolt URL
NEO4J_USER=neo4j # default Docker/Neo4j Desktop username unless you changed it
NEO4J_PASSWORD=password # replace with your real Neo4j password

# ============= Localization =============
MIROFISH_TIMEZONE=us_eastern # examples: us_eastern, us_pacific, eu_central, eu_london, asia_beijing
MIROFISH_LOCALE=en-US # language/locale for generated content
MIROFISH_REGION=US # region hint for generated content and defaults

# ============= Flask =============
SECRET_KEY=mirofish-secret-key # replace in production with a long random secret
FLASK_DEBUG=True # True for local development, False for production

# ============= OASIS Simulation =============
OASIS_DEFAULT_MAX_ROUNDS=10 # higher runs longer simulations, lower is faster and cheaper

# ============= Report Agent =============
REPORT_AGENT_MAX_TOOL_CALLS=5 # increase for deeper research, lower for cheaper/faster runs
REPORT_AGENT_MAX_REFLECTION_ROUNDS=2 # more rounds can improve depth but cost more
REPORT_AGENT_TEMPERATURE=0.5 # lower is more deterministic, higher is more creative
