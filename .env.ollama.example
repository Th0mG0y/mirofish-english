# ============================================
# MiroFish Configuration (Local Ollama)
# Copy this file to .env and fill in your local model names
# ============================================

# ============= Main App LLM =============
MIROFISH_LLM_PROVIDER=ollama # native Ollama provider (local inference)
OLLAMA_BASE_URL=http://localhost:11434/v1 # Ollama OpenAI-compatible endpoint
OLLAMA_MODEL_NAME=qwen3:14b # replace with your Ollama chat model name
LLM_MODEL_NAME=qwen3:14b # fallback model name (used by components that read this directly)
# Leave blank because this preset is fully local.
LLM_API_KEY=
LLM_BASE_URL=
OPENAI_CLI_USE_CREDENTIALS=false
OPENAI_CLI_CREDENTIALS_FILE=~/.codex/auth.json
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_NAME=claude-sonnet-4-6 # unused in this preset unless you later switch a slot to anthropic
CLAUDE_CLI_USE_CREDENTIALS=false
CLAUDE_CLI_CREDENTIALS_FILE=~/.claude/.credentials.json

# ============= Ollama Cloud Web Search (optional) =============
# Sign up at https://ollama.com for a free API key to enable built-in web search.
# Leave blank to disable web search (simulations still work, just without search enrichment).
OLLAMA_API_KEY=

# ============= Search =============
MIROFISH_SEARCH_PROVIDER=ollama # uses Ollama cloud web search when OLLAMA_API_KEY is set
MIROFISH_SEARCH_MODEL=qwen3:14b # can match the main chat model
MIROFISH_MAX_SEARCHES_PER_AGENT=5 # only matters if OLLAMA_API_KEY is configured
MIROFISH_ENABLE_SEARCH_ENRICHMENT=false # set to true once you have OLLAMA_API_KEY
MIROFISH_NEWS_INJECTION_INTERVAL=0 # 0 disables scheduled news injection

# ============= Graphiti Extraction LLM =============
GRAPHITI_LLM_PROVIDER=ollama # Graphiti extraction uses the native Ollama provider
GRAPHITI_LLM_API_KEY= # auto-resolved for local Ollama
GRAPHITI_LLM_BASE_URL=http://localhost:11434/v1 # same Ollama endpoint
GRAPHITI_LLM_MODEL=qwen3:14b # replace with your Ollama chat model name

# ============= Graphiti Embeddings (Ollama) =============
GRAPHITI_EMBEDDER_PROVIDER=ollama # native Ollama embedding provider path in this app
GRAPHITI_EMBEDDER_API_KEY=ollama # local placeholder token
GRAPHITI_EMBEDDER_BASE_URL=http://localhost:11434/v1 # same Ollama endpoint
GRAPHITI_EMBEDDER_MODEL=nomic-embed-text # recommended Ollama embedding model

# ============= Graphiti Reranking (Ollama) =============
# Local reranking uses embedding similarity through the same local embedding model.
GRAPHITI_RERANKER_PROVIDER=ollama # reranking uses local embedding similarity
GRAPHITI_RERANKER_API_KEY=ollama # local placeholder token
GRAPHITI_RERANKER_BASE_URL=http://localhost:11434/v1 # usually same as the embedder URL
GRAPHITI_RERANKER_MODEL=nomic-embed-text # usually same as the embedder model

# ============= Local Neo4j =============
NEO4J_URI=bolt://localhost:7687 # local Neo4j Bolt URL
NEO4J_USER=neo4j # default Neo4j username
NEO4J_PASSWORD=password # replace with your real Neo4j password

# ============= Legacy Zep Compatibility =============
# Usually leave blank in this Graphiti version.
ZEP_API_KEY=

# ============= Localization =============
MIROFISH_TIMEZONE=us_eastern # examples: us_eastern, us_pacific, eu_central, eu_london, asia_beijing
MIROFISH_LOCALE=en-US # content locale
MIROFISH_REGION=US # regional hint

# ============= Flask =============
SECRET_KEY=mirofish-secret-key # replace in production
FLASK_DEBUG=True # True for local development, False for production

# ============= OASIS Simulation =============
OASIS_DEFAULT_MAX_ROUNDS=10 # default simulation length

# ============= Report Agent =============
REPORT_AGENT_MAX_TOOL_CALLS=5 # more tool calls means deeper but costlier reports
REPORT_AGENT_MAX_REFLECTION_ROUNDS=2 # more reflection means deeper but slower reports
REPORT_AGENT_TEMPERATURE=0.5 # lower is steadier, higher is more creative
