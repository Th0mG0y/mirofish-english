# ============================================
# MiroFish Configuration (Local LM Studio)
# Copy this file to .env and replace the model names
# ============================================

# ============= Main App LLM =============
# Local OpenAI-compatible servers use the "openai" provider path.
MIROFISH_LLM_PROVIDER=openai # keep openai because LM Studio is accessed through the OpenAI-compatible path
LLM_API_KEY=lm-studio # placeholder token for local LM Studio usage
LLM_BASE_URL=http://localhost:1234/v1 # default LM Studio OpenAI-compatible endpoint
LLM_MODEL_NAME=your-loaded-lm-studio-chat-model # replace with your loaded LM Studio chat model name
OPENAI_CLI_USE_CREDENTIALS=false
OPENAI_CLI_CREDENTIALS_FILE=~/.codex/auth.json
# Leave blank because this preset is fully local.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_NAME=claude-sonnet-4-6 # unused in this preset unless you later switch a slot to anthropic
CLAUDE_CLI_USE_CREDENTIALS=false
CLAUDE_CLI_CREDENTIALS_FILE=~/.claude/.credentials.json

# ============= Search =============
# Local OpenAI-compatible servers do not provide built-in web search.
MIROFISH_SEARCH_PROVIDER=openai # left on openai path, but local search enrichment should stay disabled
MIROFISH_SEARCH_MODEL=your-loaded-lm-studio-chat-model # can match the main chat model
MIROFISH_MAX_SEARCHES_PER_AGENT=5 # only matters if you later switch search to a real cloud provider
MIROFISH_ENABLE_SEARCH_ENRICHMENT=false # keep false for fully local setups
MIROFISH_NEWS_INJECTION_INTERVAL=0 # 0 disables scheduled news injection

# ============= Graphiti Extraction LLM =============
GRAPHITI_LLM_PROVIDER=openai # Graphiti extraction also uses LM Studio through the OpenAI-compatible path
GRAPHITI_LLM_API_KEY=lm-studio # local placeholder token
GRAPHITI_LLM_BASE_URL=http://localhost:1234/v1 # same LM Studio endpoint
GRAPHITI_LLM_MODEL=your-loaded-lm-studio-chat-model # replace with your loaded LM Studio chat model name
# Reasoning effort for GPT-5.x models: none, low, medium, high, xhigh (ignored for non-GPT-5 models)
GRAPHITI_LLM_REASONING_EFFORT=low

# ============= Graphiti Embeddings (LM Studio) =============
GRAPHITI_EMBEDDER_PROVIDER=lmstudio # native LM Studio embedding provider path in this app
GRAPHITI_EMBEDDER_API_KEY=lm-studio # local placeholder token
GRAPHITI_EMBEDDER_BASE_URL=http://localhost:1234/v1 # same LM Studio endpoint
GRAPHITI_EMBEDDER_MODEL=your-loaded-lm-studio-embedding-model # replace with your loaded LM Studio embedding model name

# ============= Graphiti Reranking (LM Studio) =============
# Local reranking uses embedding similarity through the same local embedding model.
GRAPHITI_RERANKER_PROVIDER=lmstudio # reranking uses local embedding similarity
GRAPHITI_RERANKER_API_KEY=lm-studio # local placeholder token
GRAPHITI_RERANKER_BASE_URL=http://localhost:1234/v1 # usually same as the embedder URL
GRAPHITI_RERANKER_MODEL=your-loaded-lm-studio-embedding-model # usually same as the embedder model

# ============= Local Neo4j =============
NEO4J_URI=bolt://localhost:7687 # local Neo4j Bolt URL
NEO4J_USER=neo4j # default Neo4j username
NEO4J_PASSWORD=password # replace with your real Neo4j password

# ============= Legacy Zep Compatibility =============
# Usually leave blank in this Graphiti version.
ZEP_API_KEY=

# ============= Localization =============
MIROFISH_TIMEZONE=us_eastern # examples: us_eastern, us_pacific, eu_central, eu_london, asia_beijing
MIROFISH_LOCALE=en-US # content locale
MIROFISH_REGION=US # regional hint

# ============= Flask =============
SECRET_KEY=mirofish-secret-key # replace in production
FLASK_DEBUG=True # True for local development, False for production

# ============= OASIS Simulation =============
OASIS_DEFAULT_MAX_ROUNDS=10 # default simulation length

# ============= Report Agent =============
REPORT_AGENT_MAX_TOOL_CALLS=5 # more tool calls means deeper but costlier reports
REPORT_AGENT_MAX_REFLECTION_ROUNDS=2 # more reflection means deeper but slower reports
REPORT_AGENT_TEMPERATURE=0.5 # lower is steadier, higher is more creative
